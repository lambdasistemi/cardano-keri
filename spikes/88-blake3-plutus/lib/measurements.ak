use aiken/primitive/bytearray
use blake3

fn input_300() -> ByteArray {
  #""
}

fn digest_300() -> ByteArray {
  #"1309d44c9edaf51147844a5f38f884225acb365d7a5b4de34ef328671b5c6af5"
}

fn input_500() -> ByteArray {
  #""
}

fn digest_500() -> ByteArray {
  #"82c319bb3c247986a597e972b7d480973d5da5fdb36c93ffde86981575b0e540"
}

fn input_700() -> ByteArray {
  #""
}

fn digest_700() -> ByteArray {
  #"40f2bd0b346f2cb1a67c54928867bff9faaafe70de09e61315844520e5f7f915"
}

fn input_1024() -> ByteArray {
  bytearray.concat(
    input_700(),
    #"",
  )
}

fn digest_1024() -> ByteArray {
  #"42214739f095a406f3fc83deb889744ac00df831c10daa55189b5d121c855af7"
}

test measure_300() {
  blake3.verify(input_300(), digest_300())
}

test measure_500() {
  blake3.verify(input_500(), digest_500())
}

test measure_700() {
  blake3.verify(input_700(), digest_700())
}

test measure_1024() {
  blake3.verify(input_1024(), digest_1024())
}
